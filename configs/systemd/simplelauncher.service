[Unit]
Description=SimpleLauncher
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=/home/ship6081/module
# Full path to your packaged binary:
ExecStart=/home/ship6081/module/SimpleLauncher
Restart=always
RestartSec=5
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/ship6081/.Xauthority
# Optional: set DBUS session bus if required by your desktop
# Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=default.target
